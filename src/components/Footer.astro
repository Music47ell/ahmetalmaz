---
import NowPlaying from './NowPlaying.astro'
import NowWatching from './NowWatching.astro'
import Online from './Online'
import siteMetadata from '../data/siteMetadata'

const isProduction = import.meta.env.PROD
---

<footer class="border-t border-dracula-dracula mt-auto">
        <div class="max-w-3xl mx-auto px-4 py-6">

            <div class="flex flex-col sm:flex-row gap-4 items-center justify-between">
                <div class="text-center sm:text-left">
                    <p class="text-[#f8f8f2] text-sm font-medium mb-1">
                        <span class="text-[#bd93f9]">⚡</span> Enjoyed this? Support my work
                    </p>
                </div>
                <a href={siteMetadata.donationUrl} class="inline-flex items-center px-5 py-2 btn-purple bg-dracula-dracula text-[#282a36] text-sm font-semibold rounded-md transition-colors duration-200 whitespace-nowrap">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Donate
                </a>
            </div>
            {isProduction ? 
            <div class="grid grid-cols-1 gap-y-2 mt-6">
		<Online client:load/>
	</div>
	: null}
    </footer>