---
import { API_BASE_URL } from 'astro:env/client'

export interface Props {
	slug: string
	TrackViews?: boolean
	trackViews?: boolean
}

const { slug } = Astro.props
const shouldTrack = Astro.props.TrackViews ?? Astro.props.trackViews ?? false
const apiBase = API_BASE_URL
---

<span
	class="shrink-0"
	data-slug={slug}
	data-track={shouldTrack ? 'true' : 'false'}
	data-api-base={apiBase}
>0</span>

<script>
	const spans = document.querySelectorAll<HTMLSpanElement>('span[data-slug]')

	for (const span of spans) {
		const slug = span.getAttribute('data-slug')
		const shouldTrackViews = span.getAttribute('data-track') === 'true'
		const apiBase = span.getAttribute('data-api-base') ?? ''

		let fetched = false
		let mounted = true

		const fetchViews = async (): Promise<number> => {
			try {
				const res = await fetch(
					`${apiBase}/goatcounter/slug/%2Fblog%2F${encodeURIComponent(slug ?? '')}?t=${Date.now()}`,
					{
						method: 'GET',
						headers: { 'Content-Type': 'application/json' },
						cache: 'no-store',
					},
				)
				const data = await res.json()
				return Number(data.count) || 0
			} catch {
				return 0
			}
		}

		const loadViews = async () => {
			const firstViews = await fetchViews()
			if (!mounted || !slug) return
			span.textContent = String(firstViews)
			span.setAttribute('data-views', String(firstViews))

			if (!shouldTrackViews) return

			window.setTimeout(async () => {
				const nextViews = await fetchViews()
				if (!mounted) return
				const current = Number(span.getAttribute('data-views')) || 0
				const views = Math.max(current, nextViews)
				span.textContent = String(views)
				span.setAttribute('data-views', String(views))
			}, 1600)
		}

		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (!entry.isIntersecting || fetched) return
					fetched = true
					loadViews()
					if (entry.target) observer.unobserve(entry.target)
				}
			},
			{ root: null, threshold: 0.5 },
		)

		observer.observe(span)

		window.addEventListener('astro:before-swap', () => {
			mounted = false
			observer.disconnect()
		})
	}
</script>
