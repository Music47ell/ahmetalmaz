---
import siteMetadata from '../data/siteMetadata'

const { status } = Astro.response

const isProduction = import.meta.env.PROD

export interface Props {
	title: string
	excerpt: string
	slug: string
	published: Date
	updated: Date
	wordCount: number | undefined
	type: string
	noindex?: boolean
}

const { title, excerpt, slug, published, updated, wordCount, type, noindex = false } =
	Astro.props

const pageTitle =
	title === siteMetadata.name
		? siteMetadata.name
		: type === 'article'
			? title
			: title
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const canonicalHref = canonicalURL.toString()
const twitter = {
	site: `@${siteMetadata.username}`,
	author: `@${siteMetadata.username}`,
}

const normalizedSlug = slug.replace(/^\/|\/$/g, '')
const ogImageSlug =
	normalizedSlug === ''
		? 'home'
		: normalizedSlug.startsWith('blog/')
			? normalizedSlug.replace(/^blog\//, '')
			: normalizedSlug
const ogImage = new URL(`/images/og/${ogImageSlug}.png`, Astro.site)
const ogImageHref = ogImage.toString()
const siteId = `${siteMetadata.siteUrl}#website`
const personId = `${siteMetadata.siteUrl}#person`
const organizationId = `${siteMetadata.siteUrl}#organization`
const pageId = `${canonicalHref}#webpage`
const breadcrumbId = `${canonicalHref}#breadcrumb`
const imageId = `${ogImageHref}#primaryimage`
const sameAs = siteMetadata.socials.map((social) => social.url)
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta
	name="robots"
	content={`${noindex ? 'noindex, nofollow' : 'index, follow'}, max-image-preview:large, max-snippet:-1, max-video-preview:-1`}
/>
{title ? <title>{pageTitle}</title> : null}
{excerpt ? <meta name="description" content={excerpt} /> : null}
<meta name="generator" content={Astro.generator} />
{!noindex ? <link rel="canonical" href={canonicalHref} /> : null}
<link
	rel="alternate"
	type="application/rss+xml"
	title={`${siteMetadata.name} » RSS Feed`}
	href="/feed.xml"
/>
<link rel="sitemap" href="/sitemap.xml" />

{/*Favicons Meta Tags*/}
<link
	href="data:image/x-icon;base64,iVBORw0KGgoAAAANSUhEUgAAABAAAAAQEAYAAABPYyMiAAAABmJLR0T///////8JWPfcAAAACXBIWXMAAABIAAAASABGyWs+AAAAF0lEQVRIx2NgGAWjYBSMglEwCkbBSAcACBAAAeaR9cIAAAAASUVORK5CYII="
	rel="icon"
	type="image/x-icon"
/>
<link
	rel="icon"
	type="image/png"
	href="/favicons/favicon-96x96.png"
	sizes="96x96"
/>
<link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
<link rel="shortcut icon" href="/favicon.ico" />
<link
	rel="apple-touch-icon"
	sizes="180x180"
	href="/favicons/apple-touch-icon.png"
/>
<meta name="apple-mobile-web-app-title" content="Ahmet ALMAZ" />
<link rel="manifest" href="/favicons/site.webmanifest" />

{/*Open Graph Meta Tags*/}
<meta property="og:locale" content={siteMetadata.locale} />
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={excerpt} />
<meta property="og:url" content={canonicalHref} />
<meta property="og:site_name" content={siteMetadata.name} />
<meta property="og:image" content={ogImageHref} />
<meta property="og:image:alt" content={title} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

{/*Fediverse Tags*/}
<link rel="me" href="https://mastodon.social/@Music47ell" />
<link rel="me" href="https://mastodon.social/@ahmetalmaz" />
<meta name="fediverse:creator" content="@Music47ell@mastodon.social" />

{/*Twitter Meta Tags*/}
<meta name="twitter:card" content="summary_large_image" />
<meta
	name="twitter:site"
	content={type == "article" ? twitter.author : twitter.site}
/>
<meta name="twitter:creator" content={twitter.author} />

{/*JSON-LD*/}
<script
	type="application/ld+json"
	set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@graph": [
			{
				"@type": "WebPage",
				"@id": pageId,
				url: canonicalHref,
				name: title,
				isPartOf: {
					"@id": siteId,
				},
				primaryImageOfPage: {
					"@id": imageId,
				},
				image: {
					"@id": imageId,
				},
				thumbnailUrl: ogImageHref,
				datePublished: published,
				dateModified: updated,
				description: excerpt,
				inLanguage: siteMetadata.locale,
				potentialAction: [
					{
						"@type": "ReadAction",
						target: [canonicalHref],
					},
				],
			},
			...(type === 'article'
				? [
					{
						"@type": "BlogPosting",
						"@id": `${canonicalHref}#article`,
						isPartOf: {
							"@id": pageId,
						},
						author: {
							"@id": personId,
						},
						headline: title,
						datePublished: published,
						dateModified: updated,
						mainEntityOfPage: {
							"@id": pageId,
						},
						wordCount: wordCount,
						publisher: {
							"@id": organizationId,
						},
						image: {
							"@id": imageId,
						},
						thumbnailUrl: ogImageHref,
						inLanguage: siteMetadata.locale,
					},
				]
				: []),
			{
				"@type": "ImageObject",
				inLanguage: "en-US",
				"@id": imageId,
				url: ogImageHref,
				contentUrl: ogImageHref,
				width: 1200,
				height: 630,
				caption: title,
			},
			{
				"@type": "BreadcrumbList",
				"@id": breadcrumbId,
				itemListElement: [
					{
						"@type": "ListItem",
						position: 1,
						name: "Home",
						item: siteMetadata.siteUrl,
					},
					{
						"@type": "ListItem",
						position: 2,
						name: title,
						item: canonicalHref,
					},
				],
			},
			{
				"@type": "WebSite",
				"@id": siteId,
				url: siteMetadata.siteUrl,
				name: siteMetadata.name,
				description: siteMetadata.description,
				publisher: {
					"@id": organizationId,
				},
				inLanguage: siteMetadata.locale,
				potentialAction: {
					"@type": "SearchAction",
					target: `${siteMetadata.siteUrl}/blog`,
					"query-input": "required name=search_term_string",
				},
			},
			{
				"@type": "Organization",
				"@id": organizationId,
				name: siteMetadata.name,
				url: siteMetadata.siteUrl,
				sameAs,
			},
			{
				"@type": "Person",
				"@id": personId,
				name: siteMetadata.name,
				image: {
					"@type": "ImageObject",
					inLanguage: siteMetadata.locale,
					"@id": `${siteMetadata.siteUrl}${siteMetadata.avatar}`,
					url: `${siteMetadata.siteUrl}${siteMetadata.avatar}`,
					contentUrl: `${siteMetadata.siteUrl}${siteMetadata.avatar}`,
					caption: siteMetadata.name,
				},
				description: siteMetadata.description,
				sameAs,
			},
		],
	})}
/>

{isProduction ? <astro-analytics data-status={status}></astro-analytics> : null}

<script>
	if (import.meta.env.PROD) {
		const runWhenIdle = (callback) => {
			if ('requestIdleCallback' in window) {
				window.requestIdleCallback(() => callback(), { timeout: 2000 })
				return
			}

			window.setTimeout(callback, 1200)
		}

		runWhenIdle(() => {
			import('../scripts/init-favicons.ts').then((module) =>
				module.initFavicons(),
			)
		})

		runWhenIdle(() => {
			import('../scripts/init-snake.ts').then((module) => module.initSnake())
		})

		class AstroAnalytics extends HTMLElement {
			connectedCallback() {
				if (this.dataset.initialized === 'true') return
				this.dataset.initialized = 'true'

				const status = this.dataset.status
				runWhenIdle(() => {
					import('../components/Insight.ts').then((module) => {
						module.trackPageView(status)
						module.startHeartbeat()
					})
				})
			}
		}

		customElements.define('astro-analytics', AstroAnalytics)
	}
</script>
