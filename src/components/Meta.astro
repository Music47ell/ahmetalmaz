---
import siteMetadata from '../data/siteMetadata'

import { API_BASE_URL } from 'astro:env/client'

const { status } = Astro.response

const isProduction = import.meta.env.PROD

export interface Props {
	title: string
	excerpt: string
	slug: string
	published: Date
	updated: Date
	wordCount: number | undefined
	type: string
}

function formatOgDate(input: string | Date) {
	const d = new Date(input)
	if (isNaN(d.getTime())) return ''

	return d
		.toLocaleDateString('en-US', {
			month: 'short',
			day: '2-digit',
			year: 'numeric',
		})
		.toUpperCase()
}

const { title, excerpt, slug, published, updated, wordCount, type } =
	Astro.props

const pageTitle =
	title === siteMetadata.name
		? siteMetadata.name
		: type === 'article'
			? title
			: title
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const twitter = {
	site: '@',
	author: siteMetadata.username,
}

const formattedDate = formatOgDate(published)

const ogImage =
	`${API_BASE_URL}/og` +
	`?title=${encodeURIComponent(title)}` +
	`&excerpt=${encodeURIComponent(excerpt)}` +
	`&pubdate=${encodeURIComponent(formattedDate)}`
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta
	name="robots"
	content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
/>
{title ? <title>{pageTitle}</title> : null}
{excerpt ? <meta name="excerpt" content={excerpt} /> : null}
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} />
<link
	rel="alternate"
	type="application/rss+xml"
	title={`${siteMetadata.name} » RSS Feed`}
	href="/feed.xml"
/>

{/*Favicons Meta Tags*/}
<link
	href="data:image/x-icon;base64,iVBORw0KGgoAAAANSUhEUgAAABAAAAAQEAYAAABPYyMiAAAABmJLR0T///////8JWPfcAAAACXBIWXMAAABIAAAASABGyWs+AAAAF0lEQVRIx2NgGAWjYBSMglEwCkbBSAcACBAAAeaR9cIAAAAASUVORK5CYII="
	rel="icon"
	type="image/x-icon"
/>
<link
	rel="icon"
	type="image/png"
	href="/favicons/favicon-96x96.png"
	sizes="96x96"
/>
<link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
<link rel="shortcut icon" href="/favicon.ico" />
<link
	rel="apple-touch-icon"
	sizes="180x180"
	href="/favicons/apple-touch-icon.png"
/>
<meta name="apple-mobile-web-app-title" content="Ahmet ALMAZ" />
<link rel="manifest" href="/favicons/site.webmanifest" />

{/*Open Graph Meta Tags*/}
<meta property="og:locale" content={siteMetadata.locale} />
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:excerpt" content={excerpt} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={siteMetadata.name} />
<meta name="og:image" content={ogImage} />

{/*Fediverse Tags*/}
<link rel="me" href="https://mastodon.social/@Music47ell" />
<link rel="me" href="https://mastodon.social/@ahmetalmaz" />
<meta name="fediverse:creator" content="@Music47ell@mastodon.social" />

{/*Twitter Meta Tags*/}
<meta name="twitter:card" content="summary_large_image" />
<meta
	name="twitter:site"
	content={type == "article" ? twitter.author : twitter.site}
/>
<meta name="twitter:title" content={title} />
<meta name="twitter:excerpt" content={excerpt} />
<meta name="twitter:image" content={ogImage} />

{/*JSON-LD*/}
<script
	type="application/ld+json"
	set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@graph": [
			{
				"@type": "Article",
				"@id": `${siteMetadata.siteUrl}/${slug}`,
				isPartOf: {
					"@id": `${siteMetadata.siteUrl}/${slug}`,
				},
				author: {
					name: siteMetadata.name,
					"@id": siteMetadata.siteUrl,
				},
				headline: title,
				datePublished: published,
				dateModified: updated,
				mainEntityOfPage: {
					"@id": `${siteMetadata.siteUrl}/${slug}`,
				},
				wordCount: wordCount,
				publisher: {
					"@id": siteMetadata.siteUrl,
				},
				image: {
					"@id": ogImage,
				},
				thumbnailUrl: ogImage,
				inLanguage: siteMetadata.locale,
			},
			{
				"@type": "WebPage",
				"@id": `${siteMetadata.siteUrl}/${slug}`,
				url: `${siteMetadata.siteUrl}/${slug}`,
				name: title,
				isPartOf: {
					"@id": `${siteMetadata.siteUrl}/${slug}`,
				},
				primaryImageOfPage: {
					"@id": ogImage,
				},
				image: {
					"@id": ogImage,
				},
				thumbnailUrl: ogImage,
				datePublished: published,
				dateModified: updated,
				excerpt: excerpt,
				inLanguage: siteMetadata.locale,
				potentialAction: [
					{
						"@type": "ReadAction",
						target: [`${siteMetadata.siteUrl}/${slug}`],
					},
				],
			},
			{
				"@type": "ImageObject",
				inLanguage: "en-US",
				"@id": ogImage,
				url: ogImage,
				contentUrl: ogImage,
				width: 1200,
				height: 628,
				caption: title,
			},
			{
				"@type": "BreadcrumbList",
				"@id": `${siteMetadata.siteUrl}/${slug}#breadcrumb`,
				itemListElement: [
					{
						"@type": "ListItem",
						position: 1,
						name: "Blog",
						item: siteMetadata.siteUrl,
					},
					{
						"@type": "ListItem",
						position: 2,
						name: title,
					},
				],
			},
			{
				"@type": "WebSite",
				"@id": siteMetadata.siteUrl,
				url: siteMetadata.siteUrl,
				name: siteMetadata.name,
				excerpt: siteMetadata.excerpt,
				publisher: {
					"@id": siteMetadata.siteUrl,
				},
				inLanguage: "en-US",
			},
			{
				"@type": "Organization",
				"@id": siteMetadata.siteUrl,
				name: siteMetadata.name,
				url: siteMetadata.siteUrl,
				sameAs: [siteMetadata.socials.map((url) => url.url)],
			},
			{
				"@type": "Person",
				"@id": siteMetadata.siteUrl,
				name: siteMetadata.name,
				image: {
					"@type": "ImageObject",
					inLanguage: siteMetadata.locale,
					"@id": `${siteMetadata.siteUrl}${siteMetadata.avatar}`,
					url: `${siteMetadata.siteUrl}${siteMetadata.avatar}`,
					contentUrl: `${siteMetadata.siteUrl}${siteMetadata.avatar}`,
					caption: siteMetadata.name,
				},
				excerpt: siteMetadata.excerpt,
				sameAs: [siteMetadata.socials.map((url) => url.url)],
			},
		],
	})}
/>

{isProduction ? <astro-analytics data-status={status}></astro-analytics> : null}

<script>
	if (import.meta.env.PROD) {
		const runWhenIdle = (callback) => {
			if ('requestIdleCallback' in window) {
				window.requestIdleCallback(() => callback(), { timeout: 2000 })
				return
			}

			window.setTimeout(callback, 1200)
		}

		runWhenIdle(() => {
			import('../scripts/init-favicons.ts').then((module) =>
				module.initFavicons(),
			)
		})

		runWhenIdle(() => {
			import('../scripts/init-snake.ts').then((module) => module.initSnake())
		})

		class AstroAnalytics extends HTMLElement {
			connectedCallback() {
				if (this.dataset.initialized === 'true') return
				this.dataset.initialized = 'true'

				const status = this.dataset.status
				runWhenIdle(() => {
					import('../components/Insight.ts').then((module) => {
						module.trackPageView(status)
						module.startHeartbeat()
					})
				})
			}
		}

		customElements.define('astro-analytics', AstroAnalytics)
	}
</script>
