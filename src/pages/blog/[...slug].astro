---
import ContentLayout from "../../layouts/ContentLayout.astro";
import { fetchPublicPostBySlug } from "../../libs/fetchAPI";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");

const post = await fetchPublicPostBySlug(slug);
if (!post) return Astro.redirect("/404");
---

<ContentLayout
	title={post.frontmatter.title}
	description={post.frontmatter.excerpt}
	published_at={post.frontmatter.published}
	lastModified={post.frontmatter.updated}
	readingTime={post.frontmatter.readingTime}
	wordsCount={post.frontmatter.wordCount}
	slug={post.frontmatter.slug}
	toot={post.toot}
>
	<div set:html={post.content} />
</ContentLayout>
