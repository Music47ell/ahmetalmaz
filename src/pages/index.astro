---
import BaseLayout from '../layouts/BaseLayout.astro'
import siteMetadata from '../data/siteMetadata'
import Link from '../components/Link.astro'
import lyrics from '../data/lyrics/index.json'

const randomLyric = lyrics[Math.floor(Math.random() * lyrics.length)] ?? null

const getBadgeAriaLabel = (section: string, url: string) => {
	try {
		const parsed = new URL(url)
		const host = parsed.hostname.replace(/^www\./, '')
		return `${section}: ${host}`
	} catch {
		return section
	}
}
---

<BaseLayout
	title={siteMetadata.name}
	excerpt={siteMetadata.description}
	type="website"
	slug="/"
>
	<main>
		<div class="p-6 border border-dracula-dracula">
			<p class="leading-relaxed">
				I began this journey back in 2013. Currently my focus is on
				<strong class="text-dracula-marcelin"> back-end web development</strong>,
				<strong class="text-dracula-marcelin"> open-source software</strong> and
				<strong class="text-dracula-marcelin"> self-hosting</strong>
			</p>
		</div>

		<div class="p-6 border border-dracula-dracula">
			<div id="wave-container" class="w-full h-[120px]"></div>
		</div>
		{
			randomLyric && (
				<div class="p-6 border border-dracula-dracula">
					<p class="text-dracula-cullen">
						<span class="whitespace-pre-line">{randomLyric.lyric}</span>
					</p>
					<span class="mx-1">—</span>
						<a
							href={randomLyric.link}
							class="text-dracula-vanHelsing hover:underline"
							target="_blank"
							rel="noopener noreferrer"
						>
							{randomLyric.band}
						</a>
						<span> · {randomLyric.song}</span>
				</div>
			)
		}

		<div class="p-6 border border-dracula-dracula">
			<h2 class="text-xl font-semibold mb-4">Donate</h2>
			<ul class="grid grid-cols-3 md:grid-cols-5 gap-2 list-inside mb-4">
				{
					siteMetadata.donate.map((badge) => (
						<li>
							<a
								href={badge.url}
								aria-label={getBadgeAriaLabel('Donate', badge.url)}
								class="block w-[88px] h-[31px] hover:opacity-80 transition"
							>
								<img
									src={badge.img}
									alt=""
									class="w-full h-full object-contain"
								/>
							</a>
						</li>
					))
				}
			</ul>
			<h2 class="text-xl font-semibold mb-4">Social</h2>
			<ul class="grid grid-cols-3 md:grid-cols-5 gap-2 list-inside mb-4">
				{
					siteMetadata.social.map((badge) => (
						<li>
							<a
								href={badge.url}
								aria-label={getBadgeAriaLabel('Social', badge.url)}
								class="block w-[88px] h-[31px] hover:opacity-80 transition"
							>
								<img
									src={badge.img}
									alt=""
									class="w-full h-full object-contain"
								/>
							</a>
						</li>
					))
				}
			</ul>
			<h2 class="text-xl font-semibold mb-4">Uses</h2>
			<ul class="grid grid-cols-3 md:grid-cols-5 gap-2 list-inside mb-4">
				{
					siteMetadata.uses.map((badge) => (
						<li>
							<a
								href={badge.url}
								aria-label={getBadgeAriaLabel('Uses', badge.url)}
								class="block w-[88px] h-[31px] hover:opacity-80 transition"
							>
								<img
									src={badge.img}
									alt=""
									class="w-full h-full object-contain"
								/>
							</a>
						</li>
					))
				}
			</ul>
			<h2 class="text-xl font-semibold mb-4">Stack</h2>
			<ul class="grid grid-cols-3 md:grid-cols-5 gap-2 list-inside mb-4">
				{
					siteMetadata.stack.map((badge) => (
						<li>
							<a
								href={badge.url}
								aria-label={getBadgeAriaLabel('Stack', badge.url)}
								class="block w-[88px] h-[31px] hover:opacity-80 transition"
							>
								<img
									src={badge.img}
									alt=""
									class="w-full h-full object-contain"
								/>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</main>
</BaseLayout>

<script>
	const container = document.getElementById('wave-container')
	if (container) {
		const runWhenIdle = (callback) => {
			if ('requestIdleCallback' in window) {
				window.requestIdleCallback(() => callback(), { timeout: 2000 })
				return
			}

			window.setTimeout(callback, 1200)
		}

		let booted = false
		const boot = () => {
			if (booted) return
			booted = true
			import('../scripts/init-siri-wave.ts').then((module) =>
				module.startSiriWave(container),
			)
		}

		if ('IntersectionObserver' in window) {
			const observer = new IntersectionObserver(
				(entries) => {
					if (!entries.some((entry) => entry.isIntersecting)) return
					observer.disconnect()
					runWhenIdle(boot)
				},
				{ rootMargin: '160px' },
			)

			observer.observe(container)
		} else {
			runWhenIdle(boot)
		}
	}
</script>
