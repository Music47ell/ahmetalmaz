{
  "name": "ahmet-almaz",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro telemetry disable && astro dev",
    "start": "astro telemetry disable && astro dev",
    "build": "astro telemetry disable && bun run generate:og && astro build",
    "deploy": "bun run build && wrangler deploy --config dist/server/wrangler.json",
    "deploy:dry-run": "bun run build && wrangler deploy --dry-run --config dist/server/wrangler.json",
    "preview": "astro telemetry disable && astro preview",
    "astro": "astro",
    "check": "astro check",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "update": "bunx npm-check-updates --format group --interactive",
    "generate-types": "wrangler types",
    "generate:og": "bun src/scripts/generate-og.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.9",
    "astro-expressive-code": "^0.44.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "unist-util-visit": "^5.1.0",
    "wrangler": "^4.111.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "^1.3.14",
    "@types/sanitize-html": "^2.16.1",
    "@types/unist": "^3.0.3",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.3.0",
    "sanitize-html": "^2.17.6",
    "satori": "^0.28.0"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
